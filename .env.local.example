# Telegram Login Widget (BotFather → Bot Settings → Web Login)
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
TELEGRAM_REDIRECT_URI=https://bayanuz.vercel.app/api/auth/telegram/callback

# Firebase Admin SDK service account JSON (entire JSON pasted as a single-line string).
# Source: Firebase Console → Project Settings → Service Accounts → Generate new private key
# IMPORTANT: \n inside private_key MUST stay as the literal two characters \n (the code unescapes them).
FIREBASE_SERVICE_ACCOUNT=
